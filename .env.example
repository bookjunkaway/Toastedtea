# Book Junk Away Meta Ad Studio — environment variables
#
# All optional. Add them in Vercel → Settings → Environment Variables and
# redeploy. The app degrades gracefully without each one.

# ── AI imagery + Prompt Bar ───────────────────────────────────────────────
# Google AI Studio key (https://aistudio.google.com/app/apikey).
# Without it: /quick uses free Pollinations imagery, Prompt Bar uses
# heuristic template selection.
GEMINI_API_KEY=

# ── Lead emails ───────────────────────────────────────────────────────────
# Resend (https://resend.com — free tier 3000 emails/month).
# Without it: leads still save locally to /leads but no email is sent.
RESEND_API_KEY=
# Optional override of the From address. Defaults to onboarding@resend.dev
# for testing. Verify your domain in Resend, then set to leads@yourdomain.
RESEND_FROM=

# ── Per-ad analytics ──────────────────────────────────────────────────────
# Upstash Redis (https://console.upstash.com — free 10K req/day).
# Without these: per-ad analytics counters work within a single serverless
# container but don't persist across cold starts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional generic webhook (Zapier / Make.com) ──────────────────────────
# Every share-to-win entry on a proof page is POSTed here as JSON.
NEXT_PUBLIC_GIVEAWAY_WEBHOOK=
# Every lead-form submission is POSTed here in addition to the email.
NEXT_PUBLIC_LEAD_WEBHOOK=
